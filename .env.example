# Database (Neon)
# Pooled connection for runtime queries (use -pooler hostname)
DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?connect_timeout=15&sslmode=require
# Direct connection for migrations (use non-pooler hostname)
DATABASE_URL_UNPOOLED=postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Anthropic API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# NextAuth
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000

# Statsig
STATSIG_SERVER_SECRET_KEY=your_statsig_server_secret_key_here
NEXT_PUBLIC_STATSIG_CLIENT_KEY=your_statsig_client_key_here

# Resend
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL=your_email@example.com
RESEND_AUDIENCE_ID=your_resend_audience_id_here

# Encryption (for confirmation tokens - must match lunastak.io marketing site)
ENCRYPTION_KEY=your_32_byte_hex_key_here

# App URL (for confirmation links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Unstructured.io API for document extraction
UNSTRUCTURED_API_KEY=your_unstructured_api_key_here
