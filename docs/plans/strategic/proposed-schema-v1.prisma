// ============================================================================
// LUNASTAK SCHEMA V1: PROJECT-BASED SYNTHESIS ARCHITECTURE
// ============================================================================
//
// Design Principles:
// 1. Project = boundary for strategic understanding (enables multi-project future)
// 2. Fragments = raw material from Conversations or Documents
// 3. DimensionalSynthesis = compressed understanding per Tier 1 dimension
// 4. Hybrid storage: structured where queryable, JSONB where emergent
// 5. Simple now, extensible later
//
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// USER & AUTH (unchanged from current schema)
// ============================================================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  projects      Project[]
  conversations Conversation[]
  documents     Document[]
  feedbacks     Feedback[]
  accounts      Account[]
  sessions      Session[]

  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================================
// PROJECT: The boundary for "a strategic understanding"
// ============================================================================

model Project {
  id          String   @id @default(cuid())
  userId      String
  name        String   // "Acme Corp Strategy 2026"
  description String?  @db.Text
  status      String   @default("active") // active | archived | deleted

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Future extensibility flags
  // When you add multi-user: add ProjectMember junction table
  // When you add analytics: add allowAnonymousAnalytics Boolean

  // Relations
  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversations         Conversation[]
  fragments             Fragment[]
  dimensionalSyntheses  DimensionalSynthesis[]
  generatedOutputs      GeneratedOutput[]
  extractionRuns        ExtractionRun[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

// ============================================================================
// FRAGMENT SOURCES: Conversations and Documents
// ============================================================================

model Conversation {
  id               String   @id @default(cuid())
  projectId        String
  userId           String?  // Nullable for guest sessions (if you support that)

  // Conversation state
  status           String   @default("in_progress") // in_progress | completed | abandoned
  currentPhase     String   @default("INITIAL") // INITIAL | LENS_SELECTION | QUESTIONING | EXTRACTION | GENERATION
  selectedLens     String?
  questionCount    Int      @default(0)

  // Experiment tracking
  experimentVariant String?

  // Timestamps
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  project          Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user             User?            @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages         Message[]
  fragments        Fragment[]
  events           Event[]
  extractionRuns   ExtractionRun[]

  @@index([projectId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([experimentVariant])
}

model Message {
  id                  String   @id @default(cuid())
  conversationId      String
  role                String   // assistant | user
  content             String   @db.Text
  stepNumber          Int
  timestamp           DateTime @default(now())

  // Optional metadata
  confidenceScore     String?  // HIGH | MEDIUM | LOW
  confidenceReasoning String?  @db.Text
  annotations         String?  @db.Text

  // Relations
  conversation        Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  fragments           Fragment[]   // Fragments can reference specific messages

  @@index([conversationId])
  @@index([timestamp])
}

// ============================================================================
// DOCUMENT MODEL: DEFERRED
// ============================================================================
// The Document model has been deferred until the interaction model is validated.
// Current approach: Documents create Conversations with extracted text in Message.
//
// When to add Document model:
// 1. Voice memo feature is ready (transcriptions need Document storage)
// 2. Interaction model is validated (Mode A/B/C decision made)
// 3. Direct extraction mode is implemented
//
// See: docs/plans/strategic/document-workflow-integration.md
// Linear issues:
//   - HUM-32: Research document interaction models
//   - HUM-33: Prototype hybrid preview (Mode C)
//   - HUM-34: Implement Document model
//   - HUM-35: Voice memo feature
// ============================================================================

// ============================================================================
// FRAGMENTS: Raw material extracted from sources
// ============================================================================

model Fragment {
  id          String   @id @default(cuid())
  projectId   String

  // Source: currently only Conversation (Document deferred)
  conversationId  String?
  messageId       String?  // Specific message if from conversation

  // Content
  content         String   @db.Text
  contentType     String   @default("theme") // theme | insight | quote | stat | principle

  // Lifecycle (invisible to user, used for background cleanup)
  status          String   @default("active") // active | archived | soft_deleted
  archivedAt      DateTime?
  archivedReason  String?  // synthesis_validated | duplicate | low_quality
  softDeletedAt   DateTime?

  // Metadata
  capturedAt      DateTime @default(now())
  extractedBy     String?  // model name (claude-opus-4, etc.)
  confidence      String?  // HIGH | MEDIUM | LOW

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  project         Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  conversation    Conversation?         @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  message         Message?              @relation(fields: [messageId], references: [id], onDelete: SetNull)
  dimensionTags   FragmentDimensionTag[]

  @@index([projectId])
  @@index([conversationId])
  @@index([status])
  @@index([capturedAt])
}

// ============================================================================
// DIMENSIONAL TAGGING: Many-to-many with metadata
// ============================================================================

model FragmentDimensionTag {
  id           String   @id @default(cuid())
  fragmentId   String
  dimension    String   // Tier 1: CUSTOMER_MARKET | PROBLEM_OPPORTUNITY | etc.

  // Tag metadata (enables ML training, confidence tracking)
  confidence   String?  // How confident is this tag?
  reasoning    String?  @db.Text // Why was this tagged here?
  taggedBy     String?  // model name or user_id
  taggedAt     DateTime @default(now())

  // Future: Tier 2 subdimensions (emergent)
  subdimension String?  // When subdimensions emerge, tag here

  // Relations
  fragment     Fragment @relation(fields: [fragmentId], references: [id], onDelete: Cascade)

  @@unique([fragmentId, dimension]) // Can't tag same fragment to same dimension twice
  @@index([fragmentId])
  @@index([dimension])
  @@index([subdimension])
}

// ============================================================================
// DIMENSIONAL SYNTHESIS: Compressed understanding per dimension
// ============================================================================

model DimensionalSynthesis {
  id           String   @id @default(cuid())
  projectId    String
  dimension    String   // Tier 1: CUSTOMER_MARKET | PROBLEM_OPPORTUNITY | etc.

  // Synthesis content: HYBRID structured + flexible
  // Structured fields for queryability
  summary          String?  @db.Text  // Prose summary of understanding
  keyThemes        String[] @default([]) // Array of theme strings
  keyQuotes        String[] @default([]) // Verbatim quotes from fragments
  gaps             String[] @default([]) // What's missing/unclear
  contradictions   String[] @default([]) // Conflicting fragments

  // JSONB for emergent Tier 2 subdimensions
  subdimensions    Json?
  // Example subdimensions structure:
  // {
  //   "customer_segments": {
  //     "enterprise": { summary: "...", fragments: [...] },
  //     "smb": { summary: "...", fragments: [...] }
  //   },
  //   "buyer_personas": [...]
  // }

  // Quality metrics
  confidence       String   @default("LOW") // HIGH | MEDIUM | LOW
  coverage         String?  // comprehensive | partial | sparse
  fragmentCount    Int      @default(0) // How many fragments contributed

  // Versioning (lightweight)
  synthesisVersion String   @default("v1") // Increment when synthesis format changes

  // Temporal
  lastSynthesizedAt DateTime @default(now())
  synthesizedBy     String?  // model name

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  project           Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, dimension]) // One synthesis per dimension per project
  @@index([projectId])
  @@index([dimension])
  @@index([confidence])
  @@index([lastSynthesizedAt])
}

// ============================================================================
// GENERATED OUTPUTS: Decision Stack artifacts
// ============================================================================

model GeneratedOutput {
  id          String   @id @default(cuid())
  projectId   String
  userId      String?

  // Output metadata
  outputType  String   // vision | strategy | objectives | initiatives | principles | full_decision_stack
  version     Int      @default(1) // Allow versioning of outputs

  // Content
  content     Json     // The generated Decision Stack content

  // Generation metadata
  generatedFrom    String?  @db.Text // Which synthesis versions/fragments were used
  modelUsed        String
  promptTokens     Int?
  completionTokens Int?
  latencyMs        Int?

  // User feedback
  userFeedback     String?   // helpful | not_helpful | refined
  feedbackAt       DateTime?
  refinementNotes  String?   @db.Text

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  project         Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  extractionRuns  ExtractionRun[]  // Runs that generated this output

  @@index([projectId])
  @@index([outputType])
  @@index([createdAt])
}

// ============================================================================
// EXTRACTION RUNS: Atomic traces for evaluation and experimentation
// ============================================================================

model ExtractionRun {
  id          String   @id @default(cuid())
  projectId   String

  // What triggered this run (currently only Conversation, Document deferred)
  conversationId String?

  // Experiment tracking (for A/B tests, variant comparison)
  experimentVariant String?  // "emergent-extraction-v2", "baseline-v1", etc.
  experimentId      String?  // Group related runs (e.g., all runs in experiment "jan-2026-extraction-test")

  // What was extracted (references to created fragments)
  fragmentIds       String[] @default([]) // IDs of fragments created in this run

  // Synthesis state snapshots (for eval: did synthesis improve?)
  synthesesBefore   Json?    // Snapshot of DimensionalSynthesis records before this run
  synthesesAfter    Json?    // Snapshot of DimensionalSynthesis records after this run

  // Generated output (reference)
  generatedOutputId String?

  // Model/performance metadata
  modelUsed         String
  promptTokens      Int?
  completionTokens  Int?
  latencyMs         Int?

  // Evaluation fields (same as current Trace for backward compat)
  userFeedback      String?   // helpful | not_helpful
  feedbackAt        DateTime?
  qualityRating     String?   // good | bad
  errorCategories   String[]  @default([])  // ["wrong_dimension", "missed_theme", etc.]
  openCodingNotes   String?   @db.Text      // Freeform notes from error coding
  reviewedAt        DateTime?
  reviewedBy        String?

  createdAt         DateTime  @default(now())

  // Relations
  project           Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  conversation      Conversation?     @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  generatedOutput   GeneratedOutput?  @relation(fields: [generatedOutputId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([conversationId])
  @@index([experimentVariant])
  @@index([experimentId])
  @@index([qualityRating])
  @@index([createdAt])
}

// ============================================================================
// EVENTS & ANALYTICS (kept lightweight)
// ============================================================================

model Event {
  id             String   @id @default(cuid())
  conversationId String
  timestamp      DateTime @default(now())

  // Event classification
  eventType      String   // fake_door_click | info_icon_view | extraction_choice | etc.
  eventData      Json     // Flexible storage for event-specific data

  // Relations
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([eventType])
  @@index([timestamp])
}

model Feedback {
  id           String   @id @default(cuid())
  userId       String?
  projectId    String?  // Optional: associate feedback with project
  responseText String   @db.Text
  createdAt    DateTime @default(now())

  user         User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([projectId])
  @@index([createdAt])
}

